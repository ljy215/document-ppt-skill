{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ljy215/document-ppt-skill/schemas/slide-json.schema.json",
  "title": "Document PPT Skill Slide JSON",
  "type": "object",
  "required": ["schema_version", "deck", "slides"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "document-ppt.slide.v1"
    },
    "deck": {
      "type": "object",
      "required": ["title", "source_manifest", "language", "theme"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "source_manifest": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "enum": ["zh-CN", "en", "mixed"] },
        "theme": {
          "type": "object",
          "required": ["aspect_ratio", "font_family", "palette"],
          "additionalProperties": false,
          "properties": {
            "aspect_ratio": { "type": "string", "enum": ["16:9", "4:3"] },
            "font_family": { "type": "string", "minLength": 1 },
            "palette": {
              "type": "object",
              "required": ["background", "foreground", "accent"],
              "additionalProperties": false,
              "properties": {
                "background": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
                "foreground": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
                "accent": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
              }
            }
          }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": { "$ref": "#/$defs/slide" }
    }
  },
  "$defs": {
    "animation": {
      "type": "object",
      "required": ["type", "order", "duration_ms"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "appear", "fade-in", "fly-in", "zoom-in", "wipe"]
        },
        "order": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "delay_ms": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "direction": {
          "type": "string",
          "enum": ["left", "right", "up", "down", "center"]
        }
      }
    },
    "source_ref": {
      "type": "object",
      "required": ["page"],
      "additionalProperties": false,
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "asset_id": { "type": "string" },
        "asset_url": { "type": "string" },
        "caption": { "type": "string" },
        "evidence": { "type": "string" }
      }
    },
    "bullet": {
      "type": "object",
      "required": ["text", "animation", "source_refs"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 180 },
        "emphasis": { "type": "string", "enum": ["normal", "strong", "risk", "evidence"] },
        "animation": { "$ref": "#/$defs/animation" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_ref" }
        }
      }
    },
    "visual": {
      "type": "object",
      "required": ["asset_id", "asset_url", "kind", "caption", "layout", "animation"],
      "additionalProperties": false,
      "properties": {
        "asset_id": { "type": "string", "minLength": 1 },
        "asset_url": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["figure", "table", "page"] },
        "caption": { "type": "string" },
        "layout": {
          "type": "object",
          "required": ["x", "y", "w", "h"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 },
            "w": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "h": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        },
        "animation": { "$ref": "#/$defs/animation" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_ref" }
        }
      }
    },
    "slide": {
      "type": "object",
      "required": ["id", "title", "layout", "bullets", "visuals", "speaker_notes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^slide_[0-9]{2}$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "subtitle": { "type": "string", "maxLength": 120 },
        "layout": {
          "type": "string",
          "enum": ["title", "section", "bullets", "visual-right", "visual-left", "visual-full", "comparison", "closing"]
        },
        "bullets": {
          "type": "array",
          "maxItems": 6,
          "items": { "$ref": "#/$defs/bullet" }
        },
        "visuals": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/visual" }
        },
        "speaker_notes": { "type": "string" },
        "transition": {
          "type": "string",
          "enum": ["none", "fade", "push", "wipe"]
        }
      }
    }
  }
}
